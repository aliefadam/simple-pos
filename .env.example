# SUPABASE CONFIGURATION
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_STORAGE_BUCKET_EXPENSE_RECEIPTS=expense-receipts

# Used by `npm run migrate` to run supabase/schema.sql directly against the database.
# Get this from Supabase Dashboard > Project Settings > Database > Connection string (URI, Session pooler mode).
SUPABASE_DB_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# APP ENVIRONMENT
APP_ENV=local