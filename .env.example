# SUPABASE CONFIGURATION
#
# Rekomendasi pemisahan environment:
# - Lokal/development: simpan di `.env.local`
# - Production/server: simpan di `.env.production`
#
# Vite akan membaca `VITE_*` sesuai environment build yang dipakai.
# Contoh:
# - `npm run dev` -> `.env`, `.env.local`
# - `npm run build` dengan mode production -> `.env`, `.env.production`
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_STORAGE_BUCKET_EXPENSE_RECEIPTS=expense-receipts

# Used by `npm run migrate` to run supabase/schema.sql directly against the database.
# Get this from Supabase Dashboard > Project Settings > Database > Connection string (URI, Session pooler mode).
#
# Contoh:
# - lokal: isi di `.env.local`
# - production: isi di `.env.production`
# - jalankan: `npm run migrate -- --mode production`
SUPABASE_DB_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# APP ENVIRONMENT
APP_ENV=local
